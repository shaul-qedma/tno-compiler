@article{vizzuso2024convergence,
	abstract = {Recently, digitized-counterdiabatic (CD) quantum approximate optimization algorithm (QAOA) has been proposed to make QAOA converge to the solution of an optimization problem in fewer steps, inspired by Trotterized CD driving in continuous-time quantum annealing. In this paper, we critically revisit this approach by focusing on the paradigmatic weighted and unweighted one-dimensional MaxCut problem. We study two variants of QAOA with first and second-order CD corrections. Our results show that, indeed, higher order CD corrections allow for a quicker convergence to the exact solution of the problem at hand by increasing the complexity of the variational cost function. Remarkably, however, the total number of free parameters needed to achieve this result is independent of the particular QAOA variant analyzed for the problems considered.},
	author = {Mara Vizzuso and Gianluca Passarelli and Giovanni Cantele and Procolo Lucignano},
	doi = {10.1088/1367-2630/ad1536},
	journal = {New Journal of Physics},
	month = {jan},
	number = {1},
	pages = {013002},
	publisher = {IOP Publishing},
	title = {Convergence of digitized-counterdiabatic QAOA: circuit depth versus free parameters},
	url = {https://dx.doi.org/10.1088/1367-2630/ad1536},
	volume = {26},
	year = {2024},
	bdsk-url-1 = {https://dx.doi.org/10.1088/1367-2630/ad1536}}


